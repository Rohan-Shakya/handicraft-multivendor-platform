{
  "name": "@repo/api",
  "version": "0.0.1",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:worker": "PROCESS_MODE=worker tsx watch src/worker.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:worker": "PROCESS_MODE=worker node dist/worker.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "drizzle-kit generate && node scripts/hoist-unique-indexes.mjs",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/db/seed.ts",
    "db:seed:wipe": "WIPE_DB=1 tsx src/db/seed.ts",
    "db:seed:real": "tsx src/db/seed-real.ts",
    "db:seed:real:wipe": "WIPE_DB=1 tsx src/db/seed-real.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1029.0",
    "@aws-sdk/s3-request-presigner": "^3.1029.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/multipart": "^8.3.1",
    "@fastify/rate-limit": "9",
    "@fastify/sensible": "^5.6.0",
    "@fastify/static": "^7.0.4",
    "@fastify/swagger": "^8.15.0",
    "@fastify/swagger-ui": "^4.2.0",
    "@repo/config": "workspace:*",
    "@repo/types": "workspace:*",
    "bullmq": "^5.34.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.38.4",
    "fastify": "^4.29.0",
    "fastify-plugin": "^5.0.1",
    "ioredis": "^5.4.2",
    "nodemailer": "^8.0.5",
    "otpauth": "^9.3.6",
    "pino": "^10.3.1",
    "postgres": "^3.4.5",
    "stripe": "^17.5.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/nodemailer": "^8.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "drizzle-kit": "^0.30.4",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  }
}
