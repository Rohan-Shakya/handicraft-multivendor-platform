# Admin app (Vite + React)
# Copy to .env.local for dev overrides. Values default to localhost if missing.

# Backend API base URL — required in production, optional in dev.
VITE_API_URL=http://localhost:4000

# Observability (optional)
# Sentry DSN — when set, client errors + React render crashes are captured.
# Requires adding `@sentry/react` to package.json at the deploying stage.
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=production
VITE_SENTRY_TRACES_SAMPLE_RATE=0
VITE_SENTRY_REPLAYS_SAMPLE_RATE=0

# Surface analytics events to the devtools console (development aid).
VITE_ANALYTICS_DEBUG=0
