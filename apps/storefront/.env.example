# Storefront (Next.js)
# Copy to .env.local for dev overrides.

# Backend API URL — required. Server and client both read this.
NEXT_PUBLIC_API_URL=http://localhost:4000

# Public canonical URL of the storefront. Used for OG tags + sitemap.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Public URL of the admin / vendor portal. Vendors are redirected here after
# registering on /sell/register so they can finish setup.
NEXT_PUBLIC_ADMIN_URL=http://localhost:5173
