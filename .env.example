# =============================================================================
# Handicraft Multivendor Platform — environment template
#
# Copy this file to `.env` and fill in real values.
# `apps/api/src/lib/env.ts` validates everything at startup with Zod.
# =============================================================================

# ── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
# Process role for the API: web | worker | all
#   all     — single process runs HTTP + queues + scheduler (dev default)
#   web     — HTTP only (run multiple replicas behind a load balancer)
#   worker  — queues + scheduler only (run exactly one replica)
PROCESS_MODE=all

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5433/handicraft

# ── API ──────────────────────────────────────────────────────────────────────
API_PORT=4000
API_HOST=0.0.0.0
# REQUIRED: 16+ chars. In production generate with: openssl rand -hex 32
JWT_SECRET=change-me-in-production-min-16-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
# Separate HMAC key for CSRF tokens (16+ chars). Falls back to JWT_SECRET.
CSRF_SECRET=
# Global HMAC for signing outbound webhooks (per-endpoint secret overrides).
WEBHOOK_SIGNING_SECRET=
# Used by Next.js storefront when triggering on-demand revalidation.
REVALIDATE_SECRET=

# ── Observability ────────────────────────────────────────────────────────────
LOG_LEVEL=info
# Sentry — optional. Requires @sentry/node at runtime.
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0
# Bearer token required to scrape /metrics. Leave empty for anonymous scrape.
METRICS_AUTH_TOKEN=

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6380

# ── Frontend URLs (also used for CORS on the API) ────────────────────────────
STOREFRONT_URL=http://localhost:3000
NEXT_PUBLIC_STOREFRONT_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
VITE_API_URL=http://localhost:4000
VITE_ADMIN_URL=http://localhost:5173
# Sentry for the admin SPA (optional). Same DSN as the API is fine.
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development
VITE_SENTRY_TRACES_SAMPLE_RATE=0
VITE_SENTRY_REPLAYS_SAMPLE_RATE=0
# When `true`, the admin logs analytics events to the console for debugging.
VITE_ANALYTICS_DEBUG=false

# ── Cloudflare R2 (object storage) ───────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
# Public R2 URL surfaced to Next.js for image optimization allow-list.
NEXT_PUBLIC_R2_PUBLIC_URL=

# ── SMTP (transactional email) ───────────────────────────────────────────────
# Works with SendGrid, AWS SES, Mailgun, Resend, Postmark, or local MailHog.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Handicraft <noreply@example.com>
SMTP_SECURE=false

# ── Payment Providers — Stripe ───────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Payment Providers — eSewa ────────────────────────────────────────────────
ESEWA_MERCHANT_CODE=
ESEWA_SECRET_KEY=
ESEWA_GATEWAY_URL=https://rc-epay.esewa.com.np

# ── Payment Providers — Khalti ───────────────────────────────────────────────
KHALTI_SECRET_KEY=
KHALTI_GATEWAY_URL=https://a.khalti.com
# Optional flag to enable refund support against the Khalti API.
KHALTI_REFUND_ENABLED=false

# ── Payment Providers — Fonepay ──────────────────────────────────────────────
FONEPAY_MERCHANT_CODE=
FONEPAY_SECRET_KEY=
FONEPAY_GATEWAY_URL=https://clientapi.fonepay.com

# ── Demo / seed credentials (development only) ───────────────────────────────
# Override the default seeded passwords. Remove these in production.
ADMIN_PASSWORD=
VENDOR_PASSWORD=
CUSTOMER_PASSWORD=
# When `true`, customer reviews from non-purchasers are allowed (dev only).
ALLOW_UNVERIFIED_REVIEWS=false
